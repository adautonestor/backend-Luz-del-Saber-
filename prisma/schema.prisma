  @@index([student_id], map: "idx_competency_grades_estudiante_id")
  @@index([category_id], map: "idx_competency_grades_category_id")
  @@index([subcategory_id], map: "idx_competency_grades_subcategory_id")
  @@index([student_id, category_id, subcategory_id, quarter], map: "idx_competency_grades_composite")
  @@index([course_id, quarter], map: "idx_competency_grades_course_quarter")
  @@index([student_id, quarter], map: "idx_competency_grades_student_quarter")
}

