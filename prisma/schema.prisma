  @@index([course_id], map: "idx_course_assignments_curso_id")
  @@index([grade_id], map: "idx_course_assignments_grado_id")
  @@index([teacher_id], map: "idx_course_assignments_profesor_id")
  @@index([section_id], map: "idx_course_assignments_section_id")
