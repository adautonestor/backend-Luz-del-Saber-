/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model competency_averages {
  id                     Int                 @id @default(autoincrement())
  student_id             Int
  course_id              Int
  course_competency_id   Int
  annual_average         Decimal             @db.Decimal(4, 2)
  grading_system         String              @db.VarChar(20)
  academic_year          Int
  status                 String?             @default("active") @db.VarChar(20)
  user_id_registration   Int?
  date_time_registration DateTime?           @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime?           @updatedAt @db.Timestamptz(6)
  course_competencies    course_competencies @relation(fields: [course_competency_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_competency_averages_course_competency")
  courses                courses             @relation(fields: [course_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_competency_averages_curso")
  students               students            @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_competency_averages_student")

  @@unique([student_id, course_competency_id, academic_year], map: "uk_competency_averages")
  @@index([academic_year], map: "idx_competency_averages_año_escolar")
  @@index([course_competency_id], map: "idx_competency_averages_course_competency_id")
  @@index([course_id], map: "idx_competency_averages_curso_id")
  @@index([student_id], map: "idx_competency_averages_estudiante_id")
}

