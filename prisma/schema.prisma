generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model academic_areas {
  id                     Int            @id @default(autoincrement())
  name                   String         @unique @db.VarChar(255)
  description            String?
  order                  Int?
  status                 String?        @default("active") @db.VarChar(20)
  user_id_registration   Int?
  date_time_registration DateTime?      @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime?      @updatedAt @db.Timestamptz(6)
  competencies           competencies[]
  courses                courses[]

  @@index([order], map: "idx_academic_areas_orden")
}

/// Tipos de año académico (regular, vacacional, recuperación)
model academic_year_types {
  id                     Int              @id @default(autoincrement())
  name                   String           @db.VarChar(100)
  code                   String           @unique @db.VarChar(20)
  description            String?
  color                  String?          @db.VarChar(20)
  icon                   String?          @db.VarChar(50)
  order                  Int?
  status                 String?          @default("active") @db.VarChar(20)
  user_id_registration   Int?
  date_time_registration DateTime?        @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime?        @updatedAt @db.Timestamptz(6)
  academic_years         academic_years[]

  @@index([status], map: "idx_academic_year_types_estado")
  @@index([order], map: "idx_academic_year_types_orden")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model academic_calendar {
  id                     Int            @id @default(autoincrement())
  title                  String         @db.VarChar(255)
  description            String?
  start_date             DateTime       @db.Date
  end_date               DateTime?      @db.Date
  type                   String         @db.VarChar(20)
  academic_year_id       Int
  status                 String?        @default("active") @db.VarChar(20)
  user_id_registration   Int?
  date_time_registration DateTime?      @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime?      @updatedAt @db.Timestamptz(6)
  academic_years         academic_years @relation(fields: [academic_year_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_academic_calendar_academic_year")

  @@index([academic_year_id], map: "idx_academic_calendar_año_escolar_id")
  @@index([start_date], map: "idx_academic_calendar_fecha_inicio")
  @@index([type], map: "idx_academic_calendar_tipo")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model academic_years {
  id                          Int                           @id @default(autoincrement())
  name                        String                        @db.VarChar(255)
  year                        Int
  year_code                   String?                       @db.VarChar(20)
  type                        String?                       @default("regular") @db.VarChar(20)
  start_date                  DateTime                      @db.Date
  end_date                    DateTime                      @db.Date
  description                 String?
  close_date                  DateTime?                     @db.Timestamptz(6)
  close_reason                String?
  close_observations          String?
  file                        Json?
  copy_structure              Boolean?                      @default(false)
  status                      String?                       @default("planned") @db.VarChar(20)
  user_id_registration        Int?
  date_time_registration      DateTime?                     @default(now()) @db.Timestamptz(6)
  user_id_modification        Int?
  date_time_modification      DateTime?                     @updatedAt @db.Timestamptz(6)
  type_id                     Int?
  academic_calendar           academic_calendar[]
  academic_year_types         academic_year_types?          @relation(fields: [type_id], references: [id], onUpdate: NoAction, map: "fk_academic_years_type")
  competency_quarter_averages competency_quarter_averages[]
  course_assignments          course_assignments[]
  courses                     courses[]
  evaluation_structures       evaluation_structures[]
  grades                      grades[]
  levels                      levels[]
  matriculation               matriculation[]
  parent_meetings             parent_meetings[]
  payment_concepts            payment_concepts[]
  report_card_visibility      report_card_visibility[]
  sections                    sections[]
  student_behaviors           student_behaviors[]
  students                    students[]
  teacher_assignments         teacher_assignments[]

  @@unique([year, type], map: "uk_academic_years_año_tipo")
  @@index([status], map: "idx_academic_years_estado")
  @@index([start_date], map: "idx_academic_years_fecha_inicio")
  @@index([type_id], map: "idx_academic_years_type_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model attendance_records {
  id                                                   Int       @id @default(autoincrement())
  student_id                                           Int
  date                                                 DateTime  @db.Date
  entry_time1                                          DateTime? @db.Timestamptz(6)
  entry_status1                                        String?   @db.VarChar(20)
  registered_by_entry1                                 Int?
  exit_time1                                           DateTime? @db.Timestamptz(6)
  exit_status1                                         String?   @db.VarChar(20)
  registered_by_exit1                                  Int?
  entry_time2                                          DateTime? @db.Timestamptz(6)
  entry_status2                                        String?   @db.VarChar(20)
  registered_by_entry2                                 Int?
  exit_time2                                           DateTime? @db.Timestamptz(6)
  exit_status2                                         String?   @db.VarChar(20)
  registered_by_exit2                                  Int?
  observations                                         String?
  late_justified                                       Boolean?  @default(false)
  late_justification                                   String?
  justified_by                                         Int?
  justification_date                                   DateTime? @db.Timestamptz(6)
  registration_type                                    String?   @default("qr") @db.VarChar(20)
  status                                               String?   @default("active") @db.VarChar(20)
  user_id_registration                                 Int?
  date_time_registration                               DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification                                 Int?
  date_time_modification                               DateTime? @db.Timestamptz(6)
  quarter                                              Int?
  absence_justified                                    Boolean?  @default(false)
  users_attendance_records_justified_byTousers         users?    @relation("attendance_records_justificada_porTousers", fields: [justified_by], references: [id], onUpdate: NoAction, map: "fk_attendance_records_justificada_por")
  users_attendance_records_registered_by_entry1Tousers users?    @relation("attendance_records_registrado_por_entrada1Tousers", fields: [registered_by_entry1], references: [id], onUpdate: NoAction, map: "fk_attendance_records_registrado_entrada1")
  users_attendance_records_registered_by_entry2Tousers users?    @relation("attendance_records_registrado_por_entrada2Tousers", fields: [registered_by_entry2], references: [id], onUpdate: NoAction, map: "fk_attendance_records_registrado_entrada2")
  users_attendance_records_registered_by_exit1Tousers  users?    @relation("attendance_records_registrado_por_salida1Tousers", fields: [registered_by_exit1], references: [id], onUpdate: NoAction, map: "fk_attendance_records_registrado_salida1")
  users_attendance_records_registered_by_exit2Tousers  users?    @relation("attendance_records_registrado_por_salida2Tousers", fields: [registered_by_exit2], references: [id], onUpdate: NoAction, map: "fk_attendance_records_registrado_salida2")
  students                                             students  @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_attendance_records_student")

  @@unique([student_id, date], map: "uk_attendance_records")
  @@index([student_id], map: "idx_attendance_records_estudiante_id")
  @@index([date], map: "idx_attendance_records_fecha")
  @@index([date(sort: Desc), student_id], map: "idx_attendance_records_month")
  @@index([date, status], map: "idx_attendance_records_date_status")
  @@index([student_id, date], map: "idx_attendance_records_student_date")
  @@index([quarter], map: "idx_attendance_records_quarter")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model attendance_schedules {
  id                     Int       @id @default(autoincrement())
  entry1_start_time      DateTime  @db.Time(6)
  entry1_limit_time      DateTime  @db.Time(6)
  exit1_expected_time    DateTime  @db.Time(6)
  entry2_start_time      DateTime? @db.Time(6)
  entry2_limit_time      DateTime? @db.Time(6)
  exit2_expected_time    DateTime? @db.Time(6)
  tolerance_minutes      Int?      @default(15)
  applicable_days        Json?
  status                 String?   @default("active") @db.VarChar(20)
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @updatedAt @db.Timestamptz(6)
  level_id               Int
  levels                 levels    @relation(fields: [level_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_attendance_schedules_level")

  @@index([status], map: "idx_attendance_schedules_activo")
  @@index([level_id], map: "idx_attendance_schedules_nivel_id")
}

model audit_logs {
  id                     Int       @id @default(autoincrement())
  action                 String    @db.VarChar(100)
  entity_type            String    @db.VarChar(100)
  entity_id              String    @db.VarChar(255)
  changes                Json?
  user_id                Int
  ip_address             String?   @db.VarChar(45)
  user_agent             String?
  timestamp              DateTime? @default(now()) @db.Timestamptz(6)
  status                 String?   @default("active") @db.VarChar(20)
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @updatedAt @db.Timestamptz(6)
  users                  users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_audit_logs_user")

  @@index([action], map: "idx_audit_logs_action")
  @@index([entity_id], map: "idx_audit_logs_entity_id")
  @@index([entity_type], map: "idx_audit_logs_entity_type")
  @@index([timestamp], map: "idx_audit_logs_timestamp")
  @@index([user_id], map: "idx_audit_logs_user_id")
}

model announcements {
  id                     Int       @id @default(autoincrement())
  title                  String    @db.VarChar(255)
  content                String
  link                   String?
  image                  String?
  file                   String?
  file_name              String?   @db.VarChar(255)
  file_type              String?   @db.VarChar(100)
  file_size              Int?
  published_by           Int
  publication_date       DateTime  @db.Timestamptz(6)
  status                 String?   @default("active") @db.VarChar(20)
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @updatedAt @db.Timestamptz(6)
  users                  users     @relation(fields: [published_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_announcements_published_by")

  @@index([status], map: "idx_announcements_active")
  @@index([publication_date], map: "idx_announcements_publication_date")
  @@index([published_by], map: "idx_announcements_published_by")
}

model capacities {
  id                     Int          @id @default(autoincrement())
  competency_id          Int
  code                   String       @unique @db.VarChar(50)
  name                   String       @db.VarChar(255)
  description            String?
  order                  Int?
  status                 String?      @default("active") @db.VarChar(20)
  user_id_registration   Int?
  date_time_registration DateTime?    @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime?    @updatedAt @db.Timestamptz(6)
  competencies           competencies @relation(fields: [competency_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_capacities_competency")

  @@index([code], map: "idx_capacities_codigo")
  @@index([competency_id], map: "idx_capacities_competencia_id")
}

